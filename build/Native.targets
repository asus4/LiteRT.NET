<Project>
  <!--
    Shared MSBuild logic for the LiteRT.NET *.Native packaging projects.
    Each Native csproj imports this file. It:
      1. Packs every runtimes/<rid>/native/* file into the nupkg under runtimes/.
      2. For ProjectReference consumers (examples / local dev), copies the
         HOST RID's native files flat into the consuming project's output dir
         so [DllImport] resolves them with no environment variable.
    External PackageReference consumers resolve runtimes/<rid>/native via
    deps.json (NATIVE_DLL_SEARCH_DIRECTORIES); see build/<id>.targets for the
    desktop copy used when this package is consumed from a NuGet feed.
  -->

  <PropertyGroup>
    <_LiteRtArch>$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture.ToString().ToLowerInvariant())</_LiteRtArch>
    <_LiteRtOS Condition="$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::OSX)))">osx</_LiteRtOS>
    <_LiteRtOS Condition="$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Windows)))">win</_LiteRtOS>
    <_LiteRtOS Condition="$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Linux)))">linux</_LiteRtOS>
    <LiteRtHostRid Condition="'$(LiteRtHostRid)' == ''">$(_LiteRtOS)-$(_LiteRtArch)</LiteRtHostRid>
  </PropertyGroup>

  <ItemGroup>
    <!-- Pack all RIDs into the package; never copy the full set to output. -->
    <None Include="$(MSBuildProjectDirectory)/runtimes/**"
          Pack="true"
          PackagePath="runtimes/%(RecursiveDir)%(Filename)%(Extension)"
          CopyToOutputDirectory="Never"
          Visible="false" />

    <!-- Flatten the host RID into the consumer's bin for ProjectReference/dev. -->
    <None Update="$(MSBuildProjectDirectory)/runtimes/$(LiteRtHostRid)/native/*"
          CopyToOutputDirectory="PreserveNewest"
          Link="%(Filename)%(Extension)" />
  </ItemGroup>
</Project>
